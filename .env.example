# ============== 数据库 ==============
# 本地开发（默认 SQLite）
DATABASE_URL=file:./dev.db

# ============== 平台配置模板 ==============

# --- Vercel / EdgeOne Pages（Turso — 零改动）---
# TURSO_DATABASE_URL=libsql://xxx.turso.io
# TURSO_AUTH_TOKEN=your-token

# --- Vercel / EdgeOne Pages（Supabase — 零改动，自动切换）---
# DB_PROVIDER=postgresql    ← 在平台后台设这个变量
# DATABASE_URL=postgres://user:pass@db.xxx.supabase.co:6543/postgres?pgbouncer=true

# --- Cloudflare Pages ---
# 1. 安装 @opennextjs/cloudflare 并创建 wrangler.toml
# 2. 绑定 D1 数据库

# ============== Auth ==============
# NEXTAUTH_SECRET 自动生成，无需手动设置。
