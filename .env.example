# ============== 数据库 ==============
# 本地开发（默认 SQLite）
DATABASE_URL=file:./dev.db

# ============== 平台配置模板 ==============

# --- Vercel / EdgeOne Pages（Turso — 推荐）---
# TURSO_DATABASE_URL=libsql://xxx.turso.io
# TURSO_AUTH_TOKEN=your-token

# --- Vercel / EdgeOne Pages（Supabase — 需改 schema）---
# 1. prisma/schema.prisma: provider = "sqlite" → "postgresql"
# 2. 运行 npx prisma generate
# 3. 设置：
# DATABASE_URL=postgres://user:pass@host:6543/postgres?pgbouncer=true
# DIRECT_URL=postgres://user:pass@host:5432/postgres

# --- Cloudflare Pages ---
# 1. 安装 @opennextjs/cloudflare 并创建 wrangler.toml
# 2. 绑定 D1 数据库

# ============== Auth ==============
# NEXTAUTH_SECRET 自动生成，无需手动设置。
# 如需固定密钥（生产环境推荐），手动设为随机字符串：
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEXTAUTH_SECRET=your-secret-here
