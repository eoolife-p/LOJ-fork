generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model UserGroup {
  id               Int     @id @default(autoincrement())
  name             String
  isAdmin          Boolean @default(false)
  storageLimit     Int     @default(2147483647) // ~2GB，减1以适配 PostgreSQL INTEGER 上限
  color            String  @default("#64748b")
  isDefault        Boolean @default(false)
  priority         Int     @default(0)
  allowApiTokens   Boolean @default(true)

  users User[]
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password      String   @default("") // OAuth 用户可为空
  emailVerified Boolean  @default(false)
  role          String   @default("user") // legacy compat
  userGroupId   Int      @default(1)
  storageLimit  Int?     // bytes, null = follow group
  bio           String   @default("")
  signature     String   @default("")
  avatar        String   @default("")
  image         String   @default("") // OAuth 头像
  githubUsername String  @default("")
  websiteUrl    String   @default("")
  oauthAccounts String   @default("[]") // [{provider,providerAccountId,username,avatar}]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userGroup   UserGroup @relation(fields: [userGroupId], references: [id], onDelete: Restrict)
  submissions Submission[]
  discussions Discussion[]
  discussionReplies DiscussionReply[]
  files File[]
  editorials  Editorial[]
  contestParticipants ContestParticipant[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Problem {
  id             Int      @id @default(autoincrement())
  title          String
  slug           String   @unique
  difficulty     String
  description    String
  inputDesc      String
  outputDesc     String
  sampleInput    String
  sampleOutput   String
  selfTestSamples String   @default("[]")
  testCases      String
  timeLimit      Int      @default(5)
  memoryLimit    Int      @default(256)
  tags           String   @default("[]")
  pinyin         String   @default("")
  aiMode         String   @default("")
  spjLanguage    String   @default("")
  spjCode        String   @default("")
  editorial      String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submissions Submission[]
  discussions Discussion[]
  subtasks    Subtask[]
  editorials  Editorial[]
}

model Submission {
  id         Int      @id @default(autoincrement())
  problemId  Int
  userId     Int
  language   String   @default("cpp")
  code       String
  status     String
  stdout     String?
  stderr     String?
  time       Int?
  memory     Int?
  createdAt  DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model Discussion {
  id          Int      @id @default(autoincrement())
  problemId   Int?
  userId      Int
  categoryId  Int?
  title       String
  content     String
  isPinned    Boolean  @default(false)
  isAnnouncement Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  problem     Problem? @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    DiscussionCategory? @relation(fields: [categoryId], references: [id])
  replies     DiscussionReply[]

  @@index([problemId])
  @@index([createdAt])
  @@index([isPinned])
  @@index([categoryId])
}

model DiscussionCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String   @default("")
  icon        String   @default("MessageSquare")
  color       String   @default("#64748b")
  sortOrder   Int      @default(0)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  discussions Discussion[]
}

model DiscussionReply {
  id           Int      @id @default(autoincrement())
  discussionId Int
  userId       Int
  content      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([createdAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // reply, mention, system, contest
  title     String
  body      String   @default("")
  link      String   @default("")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

model Message {
  id         Int      @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  title      String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  fromUser User @relation("SentMessages", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedMessages", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId])
  @@index([fromUserId])
  @@index([createdAt])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerification {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model File {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  path      String   @default("/") // 虚拟路径如 /folder/sub/
  size      Int      @default(0)    // bytes
  mimeType  String   @default("")
  url       String   @default("")   // 存储返回的 URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([path])
}

model Settings {
  id                Int      @id @default(autoincrement())
  siteName          String   @default("LOJ")
  siteIcon          String   @default("")
  imageHostingUrl   String   @default("")
  submitCooldown    Int      @default(5)
  runCooldown       Int      @default(3)
  maxSubmitsPerHour Int      @default(60)
  maxRegistersPerHour Int    @default(5)
  allowRegistration Boolean  @default(true)
  footerText        String   @default("")
  aiApiKey          String   @default("")
  aiBaseUrl         String   @default("")
  aiModels          String   @default("[]")
  trainingEnabled   Boolean  @default(true)
  contestEnabled    Boolean  @default(true)
  rankEnabled       Boolean  @default(true)
  discussionEnabled        Boolean  @default(true)
  showCustomPagesSeparator Boolean  @default(true)
  siteSubtitle             String   @default("在线评测系统")
  aiEnabled                Boolean  @default(true)
  judgeEngine              String   @default("onecompiler")
  judgeConfig              String   @default("{}")
  judgeCustomCode          String   @default("")
  storageProvider          String   @default("database")
  storageS3Endpoint        String   @default("")
  storageS3Bucket          String   @default("")
  storageS3AccessKey         String   @default("")
  storageS3SecretKey         String   @default("")
  storageS3Region            String   @default("")
  storageImageHostingUrl   String   @default("")
  maxFileSize              Int      @default(20971520) // 20MB
  homepageAnnouncement     String   @default("")
  homepageSlogan           String   @default("")
  homepageShowSubmissions  Boolean  @default(false)
  homepageShowDiscussions  Boolean  @default(false)
  oauthProviders           String   @default("[]")  // [{id,name,icon,clientId,clientSecret,enabled}]
  smtpHost                 String   @default("")
  smtpPort                 Int      @default(587)
  smtpUser                 String   @default("")
  smtpPass                 String   @default("")
  smtpFrom                 String   @default("")
  smtpSecure               Boolean  @default(false)
  turnstileSiteKey         String   @default("")
  turnstileEnabled         Boolean  @default(false)
  turnstileSecretKey       String   @default("")
  adsEnabled               Boolean  @default(false)
  adsPublisherId           String   @default("")
  adsSlots                 String   @default("{}") // {"slot_home_banner":"123","slot_problem_sidebar":"456",...}
  privacyPolicy            String   @default("")
  termsOfService           String   @default("")
  cookieConsentEnabled     Boolean  @default(true)
  sponsorEnabled           Boolean  @default(false)
  seoDescription           String   @default("")
  seoKeywords              String   @default("")
  updatedAt                DateTime @updatedAt
}

model CustomPage {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  content   String
  icon      String   @default("FileText")
  pageType  String   @default("html")
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Contest ──
model Contest {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  type        String   @default("ACM") // ACM | OI
  startTime   DateTime
  endTime     DateTime
  freezeTime  DateTime?
  password    String?  // null = 公开
  isPublic    Boolean  @default(true)
  allowHack   Boolean  @default(false)
  allowRegisterAfterStart Boolean @default(true)
  approvalRequired          Boolean @default(false)
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  problems     ContestProblem[]
  participants ContestParticipant[]
  submissions  ContestSubmission[]
  announcements ContestAnnouncement[]
  clarifications ContestClarification[]
  hacks        Hack[]
}

// 比赛题目：独立存储，不引用 Problem
model ContestProblem {
  id            Int      @id @default(autoincrement())
  contestId     Int
  order         Int      @default(0)
  title         String
  difficulty    String   @default("Easy")
  description   String
  inputDesc     String   @default("")
  outputDesc    String   @default("")
  sampleInput   String   @default("")
  sampleOutput  String   @default("")
  testCases     String   @default("[]")
  timeLimit     Int      @default(5)      // 秒
  memoryLimit   Int      @default(256)    // MB
  sourceProblemId Int?   // 从题库哪个题目复制过来的（可选）

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  submissions ContestSubmission[]
}

model ContestParticipant {
  id        Int      @id @default(autoincrement())
  contestId Int
  userId    Int
  joinedAt  DateTime @default(now())
  score     Int      @default(0)
  penalty   Int      @default(0)
  status    String   @default("approved") // approved | pending | rejected

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contestId, userId])
}

model ContestSubmission {
  id               Int      @id @default(autoincrement())
  contestId        Int
  userId           Int
  contestProblemId Int
  language         String   @default("cpp")
  code             String
  status           String
  stdout           String?
  stderr           String?
  time             Int?
  memory           Int?
  createdAt        DateTime @default(now())

  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem ContestProblem @relation(fields: [contestProblemId], references: [id], onDelete: Cascade)
  hacks Hack[]

  @@index([contestId])
  @@index([userId])
  @@index([contestId, userId])
  @@index([contestProblemId])
}

model ContestAnnouncement {
  id          Int      @id @default(autoincrement())
  contestId   Int
  title       String
  content     String
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contest     Contest  @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@index([contestId])
  @@index([createdAt])
}

// ── Training ──
model Training {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  coverImage  String   @default("")
  authorId    Int
  tags        String   @default("[]")
  difficulty  String   @default("入门")
  pinyin      String   @default("")
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  problems     TrainingProblem[]
  submissions  TrainingSubmission[]
}

// 训练题目：独立存储，不引用 Problem
model TrainingProblem {
  id            Int      @id @default(autoincrement())
  trainingId    Int
  order         Int      @default(0)
  title         String
  difficulty    String   @default("Easy")
  description   String
  inputDesc     String   @default("")
  outputDesc    String   @default("")
  sampleInput   String   @default("")
  sampleOutput  String   @default("")
  testCases     String   @default("[]")
  timeLimit     Int      @default(5)      // 秒
  memoryLimit   Int      @default(256)
  sourceProblemId Int?

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  submissions TrainingSubmission[]
}

model TrainingSubmission {
  id                Int      @id @default(autoincrement())
  trainingId        Int
  userId            Int
  trainingProblemId Int
  language          String   @default("cpp")
  code              String
  status            String
  stdout            String?
  stderr            String?
  time              Int?
  memory            Int?
  createdAt         DateTime @default(now())

  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  problem TrainingProblem @relation(fields: [trainingProblemId], references: [id], onDelete: Cascade)

  @@index([trainingId])
  @@index([userId])
  @@index([trainingId, userId])
  @@index([trainingProblemId])
}

model Subtask {
  id        Int    @id @default(autoincrement())
  problemId Int
  order     Int    @default(0)
  score     Int    @default(0)
  caseIndices String @default("[]")
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  @@index([problemId])
}

model RatingHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  contestId Int?
  rating    Int      @default(1500)
  change    Int      @default(0)
  rank      Int?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
}

model ContestClarification {
  id        Int      @id @default(autoincrement())
  contestId Int
  userId    Int
  question  String
  answer    String   @default("")
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  @@index([contestId])
  @@index([createdAt])
}

model Hack {
  id           Int      @id @default(autoincrement())
  contestId    Int?
  submissionId Int
  hackerId     Int
  testInput    String
  verdict      String   @default("Pending")
  createdAt    DateTime @default(now())
  contest     Contest? @relation(fields: [contestId], references: [id], onDelete: Cascade)
  submission  ContestSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  @@index([contestId])
  @@index([submissionId])
}

model VirtualParticipation {
  id         Int      @id @default(autoincrement())
  contestId  Int
  userId     Int
  startTime  DateTime @default(now())
  endTime    DateTime
  score      Int      @default(0)
  createdAt  DateTime @default(now())
  @@unique([contestId, userId])
  @@index([contestId])
  @@index([userId])
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  leaderId  Int
  members   String   @default("[]")
  createdAt DateTime @default(now())
}

model TeamParticipant {
  id        Int      @id @default(autoincrement())
  contestId Int
  teamId    Int
  score     Int      @default(0)
  penalty   Int      @default(0)
  joinedAt  DateTime @default(now())
  @@unique([contestId, teamId])
}

model ApiToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  token     String   @unique
  scopes    String   @default("[]")
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  @@index([userId])
  @@index([token])
}

model Webhook {
  id        Int      @id @default(autoincrement())
  url       String
  secret    String   @default("")
  events    String   @default("[]")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PlagiarismReport {
  id             Int      @id @default(autoincrement())
  submissionId   Int
  similarToId    Int
  similarity     Float    @default(0)
  details        String   @default("")
  createdAt      DateTime @default(now())
  @@index([submissionId])
  @@index([similarToId])
}

model LanguageVersion {
  id        Int      @id @default(autoincrement())
  language  String   @unique
  version   String   @default("latest")
  compileCmd String  @default("")
  runCmd    String   @default("")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  color     String   @default("#64748b")
  createdAt DateTime @default(now())
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @default("")
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Editorial {
  id        Int      @id @default(autoincrement())
  problemId Int
  userId    Int
  content   String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([userId])
}
